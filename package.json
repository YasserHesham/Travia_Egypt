{
  "name": "travia-egypt",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:seed": "turbo run db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "packageManager": "npm@10.8.0",
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "ansis": "^4.2.0",
    "chalk": "^5.6.2",
    "inquirer": "^13.4.2",
    "node-emoji": "^2.2.0",
    "ora": "^9.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
